{
  "expo": {
    "name": "Smart Transport BW",
    "slug": "smart-transport-bw",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "smarttransportbw",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smarttransportbw.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E88E5"
      },
      "package": "com.smarttransportbw.app"
    },
    "web": { "bundler": "metro", "favicon": "./assets/favicon.png" },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Allow Smart Transport BW to use your location for route search." }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
